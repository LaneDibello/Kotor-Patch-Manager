!!ARBvp1.0PARAM mvMatrix[4] = { state.matrix.modelview[0] };
PARAM mvpMatrix[4] = { state.matrix.mvp };
PARAM fogParams = state.fog.params;
TEMP vReg1, vReg2, vReg9, vReg10, vReg11;
TEMP fogTemp;
MOV	vReg1, vertex.position;
MOV	vReg2, vertex.normal;
MAD	vReg1, vReg2, program.env[12].x, vReg1;
DP4   result.position.x, mvpMatrix[0], vReg1;
DP4   result.position.y, mvpMatrix[1], vReg1;
DP4   result.position.z, mvpMatrix[2], vReg1;
DP4   result.position.w, mvpMatrix[3], vReg1;
DP4   vReg10.x, mvMatrix[0], vReg1;
DP4   vReg10.y, mvMatrix[1], vReg1;
DP4   vReg10.z, mvMatrix[2], vReg1;
MOV   vReg10.w, program.env[12].w;
DP3   vReg1.w, vReg10, vReg10;
RSQ   vReg1.w, vReg1.w;
RCP   vReg1.w, vReg1.w;
MOV   result.fogcoord, vReg1.w;
ADD fogTemp.x, -fogParams.y, vReg1.w;
SLT fogTemp.y, 0.0, state.fog.color;
MUL fogTemp.z, fogTemp.x, fogParams.w;
MUL result.color.secondary.x, fogTemp.z, fogTemp.y;
DP3   vReg11.x, mvMatrix[0], vertex.normal;
DP3   vReg11.y, mvMatrix[1], vertex.normal;
DP3   vReg11.z, mvMatrix[2], vertex.normal;
DP3   vReg11.w, vReg11, vReg11;
RSQ   vReg11.w, vReg11.w;
MUL   vReg11, vReg11, vReg11.w;
MOV   vReg9, vertex.color;
MOV   result.texcoord[0], vertex.texcoord[0];
MOV   result.texcoord[1], vertex.texcoord[1];
MOV result.color, program.env[12].w;
END