!!ARBvp1.0PARAM const0 = 0.0;
PARAM const1 = 1.0;
PARAM mvMatrix[4] = { state.matrix.modelview[0] };
PARAM mvpMatrix[4] = { state.matrix.mvp };
PARAM fogParams = state.fog.params;
TEMP vTemp;
TEMP vReg0, vReg1, vReg2, vReg3;
TEMP vReg10;
TEMP vNormalWorld;
TEMP fogTemp;
ALIAS vFinalColour = vTemp;
DP4   result.position.x, mvpMatrix[0], vertex.position;
DP4   result.position.y, mvpMatrix[1], vertex.position;
DP4   result.position.z, mvpMatrix[2], vertex.position;
DP4   result.position.w, mvpMatrix[3], vertex.position;
DP4   vReg10.x, mvMatrix[0], vertex.position;
DP4   vReg10.y, mvMatrix[1], vertex.position;
DP4   vReg10.z, mvMatrix[2], vertex.position;
DP4   vReg10.w, mvMatrix[3], vertex.position;
DP3   vNormalWorld.x, mvMatrix[0], vertex.normal;
DP3   vNormalWorld.y, mvMatrix[1], vertex.normal;
DP3   vNormalWorld.z, mvMatrix[2], vertex.normal;
DP3	vReg0.x, vReg10, vReg10;
RSQ	vReg0.x, vReg0.x;
RCP	vReg0.x, vReg0.x;
ADD	vReg0.x, -state.fog.params.y, vReg0;
MOV    result.color.xyz, state.fog.color;
MUL	result.color.w, vReg0.x, state.fog.params.w;
MOV result.fogcoord, const1;
ADD fogTemp.x, -fogParams.y, const1;
SLT fogTemp.y, 0.0, state.fog.color;
MUL fogTemp.z, fogTemp.x, fogParams.w;
MUL result.color.secondary.x, fogTemp.z, fogTemp.y;
END
